{
    "name": "gaiatools/content-accord",
    "description": "Laravel package for API versioning with composable strategies and generic negotiation dimensions",
    "keywords": [
        "content negotiation",
        "api versioning",
        "laravel",
        "content-accord",
        "api"
    ],
    "homepage": "https://github.com/GaiaTools/content-accord",
    "license": "MIT",
    "authors": [
        {
            "name": "GaiaTools",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.3|^8.4|^8.5",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0"
    },
    "require-dev": {
        "larastan/larastan": "^3.9",
        "laravel/pint": "^1.27",
        "mockery/mockery": "^1.5",
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^1.23|^2.1|^3.1",
        "phpstan/phpstan": "^2.1",
        "phpunit/php-code-coverage": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.5",
        "spatie/pest-plugin-test-time": "^1.1|^2.2"
    },
    "autoload": {
        "psr-4": {
            "GaiaTools\\ContentAccord\\": "src"
        },
        "files": [
            "src/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "GaiaTools\\ContentAccord\\Tests\\": "tests"
        }
    },
    "scripts": {
        "lint": "@php vendor/bin/pint --test",
        "lint:fix": "@php vendor/bin/pint",
        "test": "vendor/bin/pest --colors=always",
        "test-coverage": "@test --coverage",
        "test-dirty": "@test --dirty --compact",
        "analyze": "phpstan analyse",
        "phpstan": "php -d memory_limit=1G vendor/bin/phpstan analyse -c phpstan.neon"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "GaiaTools\\ContentAccord\\ContentAccordServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
